# === Database Configuration ===
DATABASE_URL=postgresql://gameuser:yourpassword@postgres:5432/game_db

# === Session Management ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_EXPIRE_HOURS=24

# === CORS Configuration ===
CORS_ORIGIN=http://localhost:5173

# === Logging (optional) ===
LOG_LEVEL=debug

# === Bootstrap admin (used only when the account does not exist yet) ===
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@poketactics.net
# Required on first deploy (min 12 chars, not a common default).
# If the account already exists, BOOTSTRAP_ADMIN_PASSWORD is synced on backend startup
# when it differs from the stored hash (minimum 8 characters).
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
