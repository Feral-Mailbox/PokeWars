# === Database Configuration ===
DATABASE_URL=postgresql://gameuser:yourpassword@postgres:5432/game_db

# === Session Management ===
SESSION_SECRET=super-secret-key
SESSION_EXPIRE_HOURS=24

# === CORS Configuration ===
CORS_ORIGIN=http://localhost:5173

# === Logging (optional) ===
LOG_LEVEL=debug

# === Bootstrap admin (used only when the account does not exist yet) ===
BOOTSTRAP_ADMIN_USERNAME=anorgandroid
BOOTSTRAP_ADMIN_EMAIL=anorgandroid@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-run
